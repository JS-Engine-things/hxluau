			<compilerflag value="-I${haxelib:hxluau}/project/lib/cffi/src" />
		</section>
		<compilerflag value="-I${haxelib:hxluau}/project/include" />

		<file name="${haxelib:hxluau}/project/src/LuauImpl.cpp" />

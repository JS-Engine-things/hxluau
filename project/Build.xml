	<files id="luau-cffi">
		<!-- we copy Ast, Bytecode, Compiler, CodeGen, Common and VM includes to custom due to Luau source being messy -->
		<compilerflag value="-I${haxelib:hxluau}/project/lib/custom/luau/include" />
		<compilerflag value="-I${haxelib:hxluau}/project/lib/custom/libffi/include" />
		<compilerflag value="-I${haxelib:hxluau}/project/lib/libffi/src" />
		<compilerflag value="-I${haxelib:hxluau}/project/lib/cffi/src" />
		<compilerflag value="-DFFI_LITTLE_ENDIAN" />
		<compilerflag value="-DFFI_STATIC_BUILD" />

		<file name="${haxelib:hxluau}/project/lib/cffi/src/main.cc" />
		<file name="${haxelib:hxluau}/project/lib/cffi/src/lua.cc" />
		<file name="${haxelib:hxluau}/project/lib/cffi/src/lib.cc" />
		<file name="${haxelib:hxluau}/project/lib/cffi/src/ffilib.cc" />
		<file name="${haxelib:hxluau}/project/lib/cffi/src/ffi.cc" />
		<file name="${haxelib:hxluau}/project/lib/cffi/src/ast.cc" />
		<file name="${haxelib:hxluau}/project/lib/cffi/src/parser.cc" />
		<file name="${haxelib:hxluau}/project/lib/cffi/src/util.cc" />
	</files>

	<files id="libffi">
		<assembler name="${haxelib:hxluau}/project/ml64wrap.cmd" />
		<compilerflag value="-I${haxelib:hxluau}/project/lib/custom/libffi/include" />
		<compilerflag value="-I${haxelib:hxluau}/project/lib/libffi/src" />
		<compilerflag value="-DFFI_BUILDING" />
		<compilerflag value="-DFFI_STATIC_BUILD" />
		<compilerflag value="-DHAVE_AS_X86_PCREL" unless="isMsvc" />

		<file name="${haxelib:hxluau}/project/lib/libffi/src/prep_cif.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/types.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/raw_api.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/java_raw_api.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/closures.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/tramp.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/debug.c" />

		<file name="${haxelib:hxluau}/project/lib/libffi/src/x86/ffi.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/x86/ffi64.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/x86/ffiw64.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/aarch64/ffi.c" />
		<file name="${haxelib:hxluau}/project/lib/libffi/src/arm/ffi.c" />

		<section unless="isMsvc">
			<section if="HXCPP_M64">
				<file name="${haxelib:hxluau}/project/lib/libffi/src/x86/unix64.S" />
				<file name="${haxelib:hxluau}/project/lib/libffi/src/x86/win64.S" />
			</section>
			<section if="HXCPP_ARM64">
				<file name="${haxelib:hxluau}/project/lib/libffi/src/aarch64/sysv.S" />
			</section>
			<section if="HXCPP_ARMV7 || HXCPP_ARMV7S">
				<file name="${haxelib:hxluau}/project/lib/libffi/src/arm/sysv.S" />
			</section>
			<section unless="HXCPP_M64 || HXCPP_ARM64 || HXCPP_ARMV7 || HXCPP_ARMV7S">
				<file name="${haxelib:hxluau}/project/lib/libffi/src/x86/sysv.S" />
			</section>
		</section>

		<section if="isMsvc">
			<section if="HXCPP_M64" unless="HXCPP_ARM64">
				<file name="${haxelib:hxluau}/project/lib/custom/libffi/asm/win64.asm" />
			</section>
			<section if="HXCPP_ARM64">
				<file name="${haxelib:hxluau}/project/lib/custom/libffi/asm/win64_armasm.asm" />
			</section>
			<section unless="HXCPP_M64 || HXCPP_ARM64">
				<file name="${haxelib:hxluau}/project/lib/custom/libffi/asm/win32.asm" />
			</section>
		</section>

	</files>

	<target id="haxe">
		<section unless="HXLUAU_DISABLE_FFI">
			<files id="libffi" />
			<files id="luau-cffi" />
		</section>
		<files id="luau" />
	</target>
</xml>
